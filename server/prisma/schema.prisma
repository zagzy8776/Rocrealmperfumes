generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  PAY_ON_DELIVERY
  WHATSAPP_CONFIRMATION
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PaymentStatus {
  UNPAID
  PAYMENT_REPORTED
  PAID
}

enum DeliveryMethod {
  PICKUP
  OWERRI_DELIVERY
  WAYBILL_PARK
  OTHER_STATES_DISPATCH
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  price       Decimal     @db.Decimal(12, 2)
  costPrice   Decimal?    @db.Decimal(12, 2)
  salePrice   Decimal?    @db.Decimal(12, 2)
  size        String?
  gender      String?
  scentFamily String?
  occasion    String?
  brandType   String?
  notes       String[]
  images      String[]
  stock       Int         @default(0)
  isFeatured  Boolean     @default(false)
  isActive    Boolean     @default(true)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String
  deliveryCity    String?
  deliveryNote    String?
  deliveryMethod  DeliveryMethod @default(PICKUP)
  deliveryFee     Decimal        @default(0) @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus  @default(UNPAID)
  paymentReportedAt DateTime?
  paidAt          DateTime?
  couponCode      String?
  manualDiscount  Decimal        @default(0) @db.Decimal(12, 2)
  discountReason  String?
  bankName        String?
  accountNumber   String?
  accountName     String?
  source          String?
  medium          String?
  campaign        String?
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  status          OrderStatus   @default(PENDING)
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  productSlug  String?
  productImage String?
  productPrice Decimal @db.Decimal(12, 2)
  quantity     Int
  total        Decimal @db.Decimal(12, 2)
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Coupon {
  id        String       @id @default(cuid())
  code      String       @unique
  type      DiscountType
  value     Decimal      @db.Decimal(12, 2)
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String?
  caption     String?
  imageUrl    String
  publicId    String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VisitorEvent {
  id          String   @id @default(cuid())
  sessionId   String?
  path        String
  title       String?
  referrer    String?
  source      String?
  device      String?
  browser     String?
  productSlug String?
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([productSlug])
  @@index([source])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  quote     String
  location  String?
  rating    Int      @default(5)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoBanner {
  id        String   @id @default(cuid())
  title     String
  message   String
  linkLabel String?
  linkUrl   String?
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockAlert {
  id          String   @id @default(cuid())
  productId   String?
  productName String
  productSlug String?
  customerName String?
  phone       String
  message     String?
  isContacted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productSlug])
  @@index([isContacted])
}
